############################
# Global Project Variables #
############################

# General
APP_NAME=AnimeApp
NODE_ENV=development

########################
# Main Server (Express) #
########################
MAIN_EXPRESS_PORT=3000
# When running locally (outside Docker)
DATA_EXPRESS_URL=http://localhost:3001
DATA_SPRING_URL=http://localhost:8080
# Logging toggles
LOG_HTTP_ENABLED=true
LOG_API_ENABLED=true

#########################
# Data Server (Express) #
#########################
DATA_EXPRESS_PORT=3001
MONGO_URL=mongodb://localhost:27017/anime_dynamic

########################
# Data Server (Spring) #
########################
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/anime_db
SPRING_DATASOURCE_USERNAME=anime_user
SPRING_DATASOURCE_PASSWORD=anime_pass
SPRING_DATASOURCE_PORT=5432

#################
# PostgreSQL DB #
#################
POSTGRES_DB=anime_db
POSTGRES_USER=anime_user
POSTGRES_PASSWORD=anime_pass

############
# MongoDB  #
############
MONGO_INITDB_DATABASE=anime_dynamic

###############
# PGAdmin     #
###############
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

#################
# Mongo Express #
#################
ME_CONFIG_MONGODB_SERVER=mongo
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin

########################
# Docker Compose helper #
########################
# Enable application services profile (leave empty to skip building app services)
# COMPOSE_PROFILES=app
