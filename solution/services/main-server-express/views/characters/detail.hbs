<div class="character-detail">
  <div class="character-header">
    <img src="{{character.image_url}}" alt="{{character.name}}">
    <div>
      <h1>{{character.name}}</h1>
      <h2 class="kanji">{{character.name_kanji}}</h2>
    </div>
  </div>

  <section class="info">
    <h3>Information</h3>
    <p><strong>Favorites:</strong> {{character.favorites}}</p>
    <p><strong>Description:</strong> {{character.about}}</p>
  </section>

  <a href="/characters">← Back to list</a>
</div>
