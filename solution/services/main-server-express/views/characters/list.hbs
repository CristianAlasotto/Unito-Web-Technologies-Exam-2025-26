<div class="characters-container">
	<h1>Characters</h1>
	
	{{#if characters}}
		<div class="characters-list">
			{{#each characters}}
				<div class="character-card">
					<h2>{{this.name}}</h2>
					<p><strong>Role:</strong> {{this.role}}</p>
					<p><strong>Status:</strong> {{this.status}}</p>
					<a href="/characters/{{this.id}}" class="btn-view">View Details</a>
				</div>
			{{/each}}
		</div>
	{{else}}
		<p>No characters found.</p>
	{{/if}}
	
	<a href="/characters/new" class="btn-create">Add New Character</a>
</div>