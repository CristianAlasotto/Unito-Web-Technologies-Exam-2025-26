{{#if warning}}
<div class="warning-banner"
	style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
	⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="characters-container">
	<h1>Characters</h1>

	{{#if characters}}
	<section class="characters-list">
		{{#each characters}}
		<article class="character-card">
			<a href="/characters/{{this.character_id}}">
				<img src="{{this.image_url}}" alt="{{this.name}}" class="character-image" />
				<h3>{{this.name}}</h3>
				{{#if this.name_kanji}}
				<p class="kanji">{{this.name_kanji}}</p>
				{{/if}}
				<p class="favorites">❤️ {{this.favorites}}</p>
			</a>
		</article>
		{{/each}}
	</section>
	{{else}}
	<p class="no-data">No characters available at the moment.</p>
	{{/if}}
</div>