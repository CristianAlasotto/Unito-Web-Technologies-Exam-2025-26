{{#if warning}}
<div class="warning-banner"
	style="background: #d50415; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
	⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="characters-container">
	<h1>Characters</h1>

	{{#if characters}}
	{{> charactersFilter}}
	<section class="characters-grid">
		{{#each characters}}
		<article class="character-card">
			<a href="/characters/{{this.character_mal_id}}">
				{{#if (isHttpUrl this.image)}}
				<img src="{{this.image}}" alt="{{this.name}}" />
				{{else}}
				<div class="card-image-placeholder">
					<img src="/images/logo.png" alt="Logo" />
				</div>
				{{/if}}
				<div class="character-card-content">
					<h3>{{this.name}}</h3>
					<div class="character-info">
						{{#if this.title}}<span>{{this.title}}</span>{{/if}}
						{{#if this.favorites}}<span>❤️ {{this.favorites}}</span>{{/if}}
						{{#if this.name_kanji}}<span>{{this.name_kanji}}</span>{{/if}}
					</div>
				</div>
			</a>
		</article>
		{{/each}}
	</section>

	{{#if pagination}}
	<nav class="pagination" aria-label="Pagination">
		{{#if pagination.hasPrev}}
		<a href="/characters?page={{pagination.prevPage}}{{filtersQuery}}" class="pagination-btn">← Previous</a>
		{{/if}}
		<span class="page-info">Page {{pagination.currentPage}} of {{pagination.totalPages}}</span>
		{{#if pagination.hasNext}}
		<a href="/characters?page={{pagination.nextPage}}{{filtersQuery}}" class="pagination-btn">Next →</a>
		{{/if}}
	</nav>
	{{/if}}
	{{else}}
	{{#unless warning}}
	<p class="no-data">No characters available at the moment.</p>
	{{/unless}}
	{{/if}}
</div>