{{#if warning}}
<div class="warning-banner"
	style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
	⚠️ {{warning}}
</div>
{{/if}}

<div class="profile-container">
	<div class="profile-header">
		<img src="{{profile.avatar_url}}" alt="{{profile.display_name}}" class="profile-avatar">
		<div class="profile-info">
			<h2>{{profile.display_name}}</h2>
			<p class="username">@{{profile.username}}</p>
			{{#if profile.email}}
			<p class="email">📧 {{profile.email}}</p>
			{{/if}}
			{{#if profile.joined}}
			<p class="joined">📅 Iscritto dal: {{profile.joined}}</p>
			{{/if}}
		</div>
		<a href="/" class="btn btn-secondary">Torna alla Home</a>
	</div>

	{{#if profile.bio}}
	<div class="profile-section profile-bio">
		<h3>Bio</h3>
		<p>{{profile.bio}}</p>
	</div>
	{{/if}}

	<div class="profile-section profile-stats">
		<h3>Statistiche Anime</h3>
		<div class="stats-grid">
			{{#if profile.watching}}
			<div class="stat-item">
				<span class="stat-value">{{profile.watching}}</span>
				<span class="stat-label">In corso</span>
			</div>
			{{/if}}
			{{#if profile.completed}}
			<div class="stat-item">
				<span class="stat-value">{{profile.completed}}</span>
				<span class="stat-label">Completati</span>
			</div>
			{{/if}}
			{{#if profile.plan_to_watch}}
			<div class="stat-item">
				<span class="stat-value">{{profile.plan_to_watch}}</span>
				<span class="stat-label">Da vedere</span>
			</div>
			{{/if}}
			{{#if profile.on_hold}}
			<div class="stat-item">
				<span class="stat-value">{{profile.on_hold}}</span>
				<span class="stat-label">In pausa</span>
			</div>
			{{/if}}
			{{#if profile.dropped}}
			<div class="stat-item">
				<span class="stat-value">{{profile.dropped}}</span>
				<span class="stat-label">Abbandonati</span>
			</div>
			{{/if}}
		</div>
	</div>

	{{#any profile.birthday profile.location profile.gender}}
	<div class="profile-section profile-details">
		<h3>Dettagli</h3>
		<ul>
			{{#if profile.birthday}}
			<li>🎂 Compleanno: {{profile.birthday}}</li>
			{{/if}}
			{{#if profile.location}}
			<li>📍 Luogo: {{profile.location}}</li>
			{{/if}}
			{{#if profile.gender}}
			<li>👤 Genere: {{profile.gender}}</li>
			{{/if}}
		</ul>
	</div>
	{{/any}}

</div>