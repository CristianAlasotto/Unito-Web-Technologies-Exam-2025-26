{{#if warning}}
<div class="warning-banner"
	style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
	⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="staff-container">
	<h1>Staff</h1>

	{{#if staff}}
	{{> staffFilter}}
	<section class="staff-grid">
		{{#each staff}}
		<article class="staff-card">
			<a href="/staff/{{this.person_mal_id}}">
				{{#if (isHttpUrl this.image_url)}}
				<img src="{{this.image_url}}" alt="{{this.name}}" />
				{{else}}
				<div class="card-image-placeholder">
					<img src="/images/logo.png" alt="Logo" />
				</div>
				{{/if}}
				<div class="staff-info">
					<h3>{{this.name}}</h3>
					<span class="name">{{this.name}}</span>
					<span class="relevant-location">{{this.relevant_location}}</span>
				</div>
			</a>
		</article>
		{{/each}}
	</section>
	{{else}}
	<p class="no-data">No staff available at the moment.</p>
	{{/if}}

	{{#if pagination}}
	<nav class="pagination" aria-label="Pagination">
		{{#if pagination.hasPrev}}
		<a href="/staff?page={{pagination.prevPage}}{{filtersQuery}}" class="pagination-btn">← Previous</a>
		{{/if}}
		<span class="page-info">Page {{pagination.currentPage}} of {{pagination.totalPages}}</span>
		{{#if pagination.hasNext}}
		<a href="/staff?page={{pagination.nextPage}}{{filtersQuery}}" class="pagination-btn">Next →</a>
		{{/if}}
	</nav>
	{{/if}}
</div>
