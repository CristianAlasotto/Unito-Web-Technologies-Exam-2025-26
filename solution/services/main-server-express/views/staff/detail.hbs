<div class="staff-detail">
	<div class="staff-header">
		<img src="{{staff.image_url}}" alt="{{staff.name}}">
		<div>
			<h1>{{staff.name}}</h1>
			<p class="staff-birthday"><strong>Birthday:</strong> {{staff.birthday}}</p>
			<p class="staff-favorites"><strong>Favorites:</strong> {{staff.favorites}}</p>
			{{#if staff.website_url}}
			<a href="{{staff.website_url}}" target="_blank" class="staff-website">Website</a>
			{{/if}}
		</div>
	</div>

	<a href="/staff" class="btn btn-secondary">← Back to Staff</a>
</div>