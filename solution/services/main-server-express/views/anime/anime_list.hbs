{{#if warning}}
<div class="warning-banner"
  style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
  ⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="anime-container">
  <h1>Animes</h1>

  {{#if animes}}
  {{> animeFilter}}
  <section class="anime-grid">
    {{#each animes}}
    <article class="anime-card">
      <a href="/anime/{{this.mal_id}}">
        {{#if (isHttpUrl this.image_url)}}
        <img src="{{this.image_url}}" alt="{{this.title}}" />
        {{else}}
        <div class="card-image-placeholder">
          <img src="/images/logo.png" alt="Logo" />
        </div>
        {{/if}}
        <div class="anime-card-content">
          <h3>{{this.title}}</h3>
          <div class="anime-info">
            {{#if this.score}}<span>Score {{this.score}}</span>{{/if}}
            {{#if this.type}}<span>{{this.type}}</span>{{/if}}
            {{#if this.episodes}}<span>{{this.episodes}} eps</span>{{/if}}
          </div>
        </div>
      </a>
    </article>
    {{/each}}
  </section>

  {{#if pagination}}
  <nav class="pagination" aria-label="Pagination">
    {{#if pagination.hasPrev}}
    <a href="/anime?page={{pagination.prevPage}}{{filtersQuery}}" class="pagination-btn">← Previous</a>
    {{/if}}
    <span class="page-info">Page {{pagination.currentPage}} of {{pagination.totalPages}}</span>
    {{#if pagination.hasNext}}
    <a href="/anime?page={{pagination.nextPage}}{{filtersQuery}}" class="pagination-btn">Next →</a>
    {{/if}}
  </nav>
  {{/if}}
  {{else}}
  {{#unless warning}}
  <p class="no-data">No anime available at the moment.</p>
  {{/unless}}
  {{/if}}
</div>
