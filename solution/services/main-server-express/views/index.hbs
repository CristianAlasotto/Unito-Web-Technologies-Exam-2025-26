<div class="hero">
  <h2>Welcome to Anime Database</h2>
  <div class="hero-description">
    <p>Explore a vast collection of anime, each with unique stories and characters that captivate audiences worldwide.
    </p>
  </div>
</div>
{{#if warning}}
<div class="warning-banner"
  style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
  ⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

{{!-- Anime carousel --}}
<div class="carousel" id="anime-carousel" data-current-page="{{animeCarousel.currentPage}}"
  data-page-size="{{animeCarousel.pageSize}}">
  <h3>Top Rated animes</h3>
  {{#if animeCarousel.hasPrev}}
  <button class="btn-left" data-prev-page="{{animeCarousel.prevPage}}">
    ←
  </button>
  {{/if}}

  <div class="carousel-container">
    {{#each popularAnimes}}
    <div class="card">
      <a href="/anime/{{this.mal_id}}">
        <img src="{{this.image_url}}" alt="{{this.title}}">
        <div class="card-body">
          <p>{{this.title}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>

  {{#if animeCarousel.hasNext}}
  <button class="btn-right" data-next-page="{{animeCarousel.nextPage}}">
    →
  </button>
  {{/if}}
</div>

{{!-- Characters carousel --}}
<div class="carousel" id="character-carousel" data-current-page="{{characterCarousel.currentPage}}"
  data-page-size="{{characterCarousel.pageSize}}">
  <h3>Most popular Characters</h3>
  {{#if characterCarousel.hasPrev}}
  <button class="btn-left" data-prev-page="{{characterCarousel.prevPage}}">
    ←
  </button>
  {{/if}}

  <div class="carousel-container">
    {{#each popularCharacters}}
    <div class="card">
      <a href="/characters/{{this.character_mal_id}}">
        <img src="{{this.image}}" alt="{{this.name}}">
        <div class="card-body">
          <p>{{this.name}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>

  {{#if characterCarousel.hasNext}}
  <button class="btn-right" data-next-page="{{characterCarousel.nextPage}}">
    →
  </button>
  {{/if}}
</div>

{{!-- Staff carousel --}}
<div class="carousel" id="staff-carousel" data-current-page="{{staffCarousel.currentPage}}"
  data-page-size="{{staffCarousel.pageSize}}">
  <h3>Some of our best Creators</h3>
  {{#if staffCarousel.hasPrev}}
  <button class="btn-left" data-prev-page="{{staffCarousel.prevPage}}">
    ←
  </button>
  {{/if}}

  <div class="carousel-container">
    {{#each popularStaff}}
    <div class="card">
      <a href="/staff/{{this.mal_id}}">
        <img src="{{this.image_url}}" alt="{{this.name}}">
        <div class="card-body">
          <p>{{this.name}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>

  {{#if staffCarousel.hasNext}}
  <button class="btn-right" data-next-page="{{staffCarousel.nextPage}}">
    →
  </button>
  {{/if}}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousels = document.querySelectorAll('.carousel');

    carousels.forEach(carousel => {
      const carouselId = carousel.id;
      const prevButton = carousel.querySelector('.btn-left');
      const nextButton = carousel.querySelector('.btn-right');

      if (prevButton) {
        prevButton.addEventListener('click', () => {
          const page = prevButton.dataset.prevPage;
          fetchCarouselData(carouselId, page);
        });
      }

      if (nextButton) {
        nextButton.addEventListener('click', () => {
          const page = nextButton.dataset.nextPage;
          fetchCarouselData(carouselId, page);
        });
      }
    });

    async function fetchCarouselData(carouselId, page) {
      const carousel = document.getElementById(carouselId);
      const pageSize = carousel.dataset.pageSize;
      const type = carouselId.split('-')[0]; // anime, character, or staff

      try {
        const response = await fetch(`/carousel/${type}?page=${page}&pageSize=${pageSize}`);
        if (!response.ok) {
          throw new Error('Network response was not ok');
        }
        const data = await response.json();

        const carouselContainer = carousel.querySelector('.carousel-container');
        carouselContainer.innerHTML = data.html;

        carousel.dataset.currentPage = data.currentPage;

        const prevButton = carousel.querySelector('.btn-left');
        if (data.hasPrev) {
          if (prevButton) {
            prevButton.dataset.prevPage = data.prevPage;
            prevButton.style.display = 'block';
          } else {
            const newPrevButton = document.createElement('button');
            newPrevButton.className = 'btn-left';
            newPrevButton.dataset.prevPage = data.prevPage;
            newPrevButton.innerHTML = '←';
            newPrevButton.addEventListener('click', () => fetchCarouselData(carouselId, data.prevPage));
            carousel.insertBefore(newPrevButton, carouselContainer);
          }
        } else {
          if (prevButton) {
            prevButton.style.display = 'none';
          }
        }

        const nextButton = carousel.querySelector('.btn-right');
        if (data.hasNext) {
          if (nextButton) {
            nextButton.dataset.nextPage = data.nextPage;
            nextButton.style.display = 'block';
          } else {
            const newNextButton = document.createElement('button');
            newNextButton.className = 'btn-right';
            newNextButton.dataset.nextPage = data.nextPage;
            newNextButton.innerHTML = '→';
            newNextButton.addEventListener('click', () => fetchCarouselData(carouselId, data.nextPage));
            carousel.appendChild(newNextButton);
          }
        } else {
          if (nextButton) {
            nextButton.style.display = 'none';
          }
        }

      } catch (error) {
        console.error('Failed to fetch carousel data:', error);
      }
    }
  });
</script>