<div class="hero">
  <h2>Welcome to Anime Database</h2>
  <div class="hero-description">
    <p>Explore a vast collection of anime, each with unique stories and characters that captivate audiences worldwide.
    </p>
  </div>
</div>
{{#if warning}}
<div class="warning-banner"
  style="background: #ff9800; color: #000; padding: 1rem; text-align: center; margin-bottom: 1rem;">
  ⚠️ {{warning}}
</div>
{{/if}}

{{#if error}}
<div class="error-message">{{error}}</div>
{{/if}}

<div class="preview-section">
  <h3>Anime</h3>
  <div class="card-container">
    {{#each animes}}
    <div class="card">
      <a href="/anime/{{this.id}}">
        <img src="{{this.image_url}}" alt="{{this.title}}">
        <div class="card-body">
          <p>{{this.title}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>
</div>

<div class="preview-section">
  <h3>Characters</h3>
  <div class="card-container">
    {{#each characters}}
    <div class="card">
      <a href="/characters/{{this.id}}">
        <img src="{{this.image_url}}" alt="{{this.name}}">
        <div class="card-body">
          <p>{{this.name}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>
</div>

<div class="preview-section">
  <h3>Staff</h3>
  <div class="card-container">
    {{#each staff}}
    <div class="card">
      <a href="/staff/{{this.id}}">
        <img src="{{this.image_url}}" alt="{{this.name}}">
        <div class="card-body">
          <p>{{this.name}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>
</div>