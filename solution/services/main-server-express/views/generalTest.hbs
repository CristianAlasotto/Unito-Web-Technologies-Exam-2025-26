<div class="container mt-5">
	<h1>{{title}}</h1>
	<p class="lead">Testing MongoDB endpoints from data-server-mongo</p>

	<!-- Favourites Section -->
	<div class="card mb-4">
		<div class="card-header {{#if favsError}}bg-danger text-white{{else}}bg-primary text-white{{/if}}">
			<h3>Favourites (/getfavs)</h3>
		</div>
		<div class="card-body">
			{{#if favsError}}
			<div class="alert alert-danger">Error: {{json favs}}</div>
			{{else}}
			<pre><code>{{json favs}}</code></pre>
			{{/if}}
		</div>
	</div>

	<!-- Ratings Section -->
	<div class="card mb-4">
		<div class="card-header {{#if ratingsError}}bg-danger text-white{{else}}bg-success text-white{{/if}}">
			<h3>Ratings (/getratings)</h3>
		</div>
		<div class="card-body">
			{{#if ratingsError}}
			<div class="alert alert-danger">Error: {{json ratings}}</div>
			{{else}}
			<pre><code>{{json ratings}}</code></pre>
			{{/if}}
		</div>
	</div>

	<!-- Stats Section -->
	<div class="card mb-4">
		<div class="card-header {{#if statsError}}bg-danger text-white{{else}}bg-info text-white{{/if}}">
			<h3>Stats (/getstats)</h3>
		</div>
		<div class="card-body">
			{{#if statsError}}
			<div class="alert alert-danger">Error: {{json stats}}</div>
			{{else}}
			<pre><code>{{json stats}}</code></pre>
			{{/if}}
		</div>
	</div>

	<a href="/" class="btn btn-secondary">Back to Home</a>
</div>

<style>
	pre {
		background-color: #f5f5f5;
		border: 1px solid #ddd;
		border-radius: 4px;
		padding: 15px;
		overflow-x: auto;
		max-height: 400px;
	}

	code {
		color: #333;
		font-size: 0.9em;
	}
</style>